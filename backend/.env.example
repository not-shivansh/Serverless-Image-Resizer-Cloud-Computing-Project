# ─── Serverless Image Resizer — Environment Configuration ───
# Copy this file to .env and fill in your actual values.
# All variables are prefixed with IMAGE_RESIZER_ to match pydantic-settings.

# ── App ──────────────────────────────────────────────────────
IMAGE_RESIZER_APP_NAME=Serverless Image Resizer API
IMAGE_RESIZER_APP_VERSION=1.0.0
IMAGE_RESIZER_DEBUG=false

# ── Image constraints ────────────────────────────────────────
IMAGE_RESIZER_MAX_FILE_SIZE_MB=5

# ── CORS (comma-separated origins) ───────────────────────────
IMAGE_RESIZER_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Storage backend: "local" for development, "s3" for AWS ───
IMAGE_RESIZER_STORAGE_BACKEND=local

# ── AWS Credentials ──────────────────────────────────────────
IMAGE_RESIZER_AWS_REGION=ap-south-1
IMAGE_RESIZER_AWS_ACCESS_KEY_ID=
IMAGE_RESIZER_AWS_SECRET_ACCESS_KEY=

# ── S3 Buckets ───────────────────────────────────────────────
IMAGE_RESIZER_S3_INPUT_BUCKET=serverless-image-resizer-buckets-input
IMAGE_RESIZER_S3_OUTPUT_BUCKET=serverless-image-resizer-buckets-output
IMAGE_RESIZER_S3_PRESIGN_EXPIRY=300

# ── CloudFront ───────────────────────────────────────────────
IMAGE_RESIZER_CLOUDFRONT_DOMAIN=
